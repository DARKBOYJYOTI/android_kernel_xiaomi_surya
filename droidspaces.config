# Swap support
CONFIG_SWAP=y

# Zswap compressed cache
CONFIG_ZSWAP=y
CONFIG_CRYPTO_LZO=y

# Zswap core dependencies
CONFIG_FRONTSWAP=y
CONFIG_ZPOOL=y
CONFIG_Z3FOLD=y
CONFIG_ZBUD=y
CONFIG_ZSMALLOC=y

# Compression (আপনি যেহেতু LZ4 ব্যবহার করতে চান)
CONFIG_LZ4_COMPRESSION=y
CONFIG_LZ4_COMPRESS=y
CONFIG_LZ4_DECOMPRESS=y
CONFIG_CRYPTO_LZ4=y

# IPC mechanisms
CONFIG_SYSCTL=y
# Keep BaikalOS stock values for VINTF-sensitive IPC options.
# CONFIG_SYSVIPC is not set
CONFIG_POSIX_MQUEUE=y

# Core namespace support
CONFIG_NAMESPACES=y
# Re-enable only the namespaces Droidspaces requires to start.
CONFIG_PID_NS=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y

# Seccomp support
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# Control groups support
CONFIG_CGROUPS=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_PIDS=y
CONFIG_MEMCG=y
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_NET_PRIO=y

# Device filesystem support
CONFIG_DEVTMPFS=y

# Overlay filesystem support
CONFIG_OVERLAY_FS=y

# Firmware loading support
CONFIG_FW_LOADER=y
CONFIG_FW_LOADER_USER_HELPER=y
# Note: CONFIG_FW_LOADER_COMPRESS not available in kernel 4.x

# Network Isolation Support
CONFIG_NET_NS=y
CONFIG_VETH=y
CONFIG_BRIDGE=y
CONFIG_NETFILTER=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_CONNTRACK_IPV4=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_NF_NAT=y
CONFIG_NF_TABLES=y
CONFIG_NF_NAT_IPV4=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_NETFILTER_XT_TARGET_TCPMSS=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_NF_NAT_REDIRECT=y
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_IP_MULTIPLE_TABLES=y

# UFW / iptables compatibility
CONFIG_NETFILTER_XT_MATCH_COMMENT=y
CONFIG_NETFILTER_XT_MATCH_STATE=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NETFILTER_XT_MATCH_MULTIPORT=y
CONFIG_NETFILTER_XT_MATCH_HL=y
CONFIG_IP_NF_TARGET_REJECT=y
CONFIG_NETFILTER_XT_TARGET_LOG=y

# Fail2ban compatibility
CONFIG_NETFILTER_XT_MATCH_RECENT=y
CONFIG_NETFILTER_XT_MATCH_LIMIT=y
CONFIG_NETFILTER_XT_MATCH_HASHLIMIT=y
CONFIG_NETFILTER_XT_MATCH_OWNER=y
CONFIG_NETFILTER_XT_MATCH_PKTTYPE=y
CONFIG_NETFILTER_XT_MATCH_MARK=y
CONFIG_NETFILTER_XT_TARGET_MARK=y

# IP sets and netfilter logging
CONFIG_IP_SET=y
CONFIG_IP_SET_HASH_IP=y
CONFIG_IP_SET_HASH_NET=y
CONFIG_NETFILTER_XT_SET=y
CONFIG_NETFILTER_NETLINK_QUEUE=y
CONFIG_NETFILTER_NETLINK_LOG=y
CONFIG_NETFILTER_XT_TARGET_NFLOG=y

# ====================
# PHASE 1: Container Runtime
# ====================
CONFIG_USER_NS=y
CONFIG_CGROUP_BPF=y
CONFIG_CHECKPOINT_RESTORE=y
CONFIG_KEYS=y
CONFIG_AUDIT=y

# ====================
# PHASE 2: Desktop Filesystems
# ====================
CONFIG_EXT4_FS=y
CONFIG_XFS_FS=y
CONFIG_BTRFS_FS=y
CONFIG_FUSE_FS=y
CONFIG_OVERLAY_FS=y
CONFIG_SQUASHFS=y
CONFIG_EFIVAR_FS=y
CONFIG_FAT_FS=y
CONFIG_VFAT_FS=y

# ====================
# PHASE 3: USB / Input / Display
# ====================
CONFIG_USB_HOST_XHCI_HCD=y
CONFIG_USB_HOST_EHCI_HCD=y
CONFIG_USB_HOST_OHCI_HCD=y
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MOUSE=y
CONFIG_TTY=y
CONFIG_VT=y
CONFIG_CONSOLE_TRANSLATIONS=y
CONFIG_HW_RANDOM=y

# ====================
# PHASE 4: Sound
# ====================
CONFIG_SOUND_CORE=y
CONFIG_SND=y
CONFIG_SND_HWDEP=y

# ====================
# PHASE 5: Router / Firewall / VPN
# ====================
CONFIG_WIREGUARD=y
CONFIG_NET_IPVTI=y
CONFIG_NET_SCHED=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_NET_SCH_SFQ=y
CONFIG_VLAN_8021Q=y
CONFIG_BONDING=y
CONFIG_IPV6_ROUTER_PREF=y
CONFIG_IPV6_MULTIPLE_TABLES=y
CONFIG_NF_TABLES_IPV6=y

# ====================
# PHASE 6: General Linux Missing Pieces
# ====================
CONFIG_POSIX_TIMERS=y
CONFIG_SYSFS=y
CONFIG_PROC_FS=y
CONFIG_TMPFS=y
CONFIG_DEVPTS_MULTIPLE_INSTANCES=y
CONFIG_AIO=y
CONFIG_INOTIFY_USER=y
CONFIG_FANOTIFY=y
CONFIG_KALLSYMS=y
CONFIG_MAGIC_SYSRQ=y
CONFIG_COREDUMP=y
